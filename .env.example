# Third-party API keys
SHODAN_API_KEY=your_shodan_api_key_here
CENSYS_API_ID=
CENSYS_API_SECRET=
ANTHROPIC_API_KEY=

# MongoDB (overridden in docker-compose)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=aimap

# Redis (overridden in docker-compose)
REDIS_URL=redis://localhost:6379/0

# Clerk auth (backend JWT verification — get issuer URL from Clerk Dashboard)
CLERK_ISSUER=
# Frontend Clerk key (set in frontend/.env.local)
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Modal serverless (set to true to dispatch attacks/scans to Modal containers)
MODAL_ENABLED=false

# Ports (for docker-compose)
FRONTEND_PORT=80
BACKEND_PORT=8000
MONGO_PORT=27017
REDIS_PORT=6379
